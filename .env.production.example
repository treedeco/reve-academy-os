# REVE ACADEMY OS — production environment template (names only; never commit values)
#
# Copy to your hosting provider secret store (e.g. Vercel Project → Settings → Environment Variables).
# Do not copy local .env.local into production.

# --- Browser-safe (public) Supabase configuration ---
# Exposed to the Next.js client bundle via NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only hosted Supabase (operator scripts only; NOT for Vercel runtime unless you add server-side jobs) ---
# Used by scripts/bootstrap-production-owner.mjs from an operator workstation.
# Never prefix with NEXT_PUBLIC_.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- One-time Owner bootstrap (operator workstation only; remove after use) ---
# Required only when running scripts/bootstrap-production-owner.mjs.
# Must NOT be set in Vercel production runtime variables.
# The login UI username is `reve`; Supabase Auth email must be reve@owner.local for the current app mapping.
OWNER_BOOTSTRAP_PASSWORD=
# Optional overrides (defaults shown in runbook):
# OWNER_BOOTSTRAP_EMAIL=reve@owner.local
# OWNER_BOOTSTRAP_DISPLAY_NAME=REVE Owner

# --- Local development / CI only (do NOT set in production hosting) ---
# OWNER_PASSWORD=
# E2E_OWNER_PASSWORD=
# SUPABASE_DB_CONTAINER=
# PLAYWRIGHT_BASE_URL=
