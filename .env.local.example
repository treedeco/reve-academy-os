# Supabase local (default Supabase CLI ports)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key

# Owner login (gitignored — set locally, never commit)
# Username at /login: reve
OWNER_PASSWORD=

# Optional alias for Playwright / integration tests
# E2E_OWNER_PASSWORD=
